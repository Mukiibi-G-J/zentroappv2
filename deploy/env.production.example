# Production env for /root/projects/zentro-appv2/backend/.env
# Copy: cp deploy/env.production.example backend/.env
# V1 stays at /root/projects/zentro-app — do not reuse its DB/Redis slots.

ENVIRONMENT=production
DJANGO_SECRET_KEY=change-me-generate-a-long-random-key
SECRET_KEY=change-me-generate-a-long-random-key

# settingsprod.py reads these (separate from V1 zentroapp_db)
DB_NAME_PROD=zentroapp_v2_db
DB_USER_PROD=jom
DB_PASSWORD_PROD=CHANGE_ME
DB_HOST_PROD=127.0.0.1

# Redis — V1 uses DB 0, MedLink 2/3, V2 uses 4
REDIS_URL=redis://127.0.0.1:6379/4

# Frontend (platform + tenant workspaces)
# DOMAIN / CORS in settingsprod.py: zentroapp.uncodedsolutions.com + *.zentroapp.uncodedsolutions.com
# API: zentroapp-api.uncodedsolutions.com + *.zentroapp-api.uncodedsolutions.com

# AWS S3 (media)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_TEST=

# Firebase push (optional)
FIREBASE_CREDENTIALS_PATH=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
